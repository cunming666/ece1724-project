{
  "name": "ece1724-checkin-system",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,green \"npm run dev -w @checkin/api\" \"npm run dev -w @checkin/web\"",
    "dev:api": "npm run dev -w @checkin/api",
    "dev:web": "npm run dev -w @checkin/web",
    "build": "npm run build --ws --if-present",
    "typecheck": "npm run typecheck --ws --if-present",
    "test": "npm run test --ws --if-present",
    "demo:bootstrap": "node scripts/demo-bootstrap.mjs",
    "db:init": "node scripts/init-sqlite.mjs",
    "prisma:generate": "npm run prisma:generate:sqlite",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:studio": "prisma studio",
    "prisma:sync:postgres": "node scripts/sync-prisma-postgres-schema.mjs",
    "prisma:generate:sqlite": "prisma generate --schema prisma/schema.prisma",
    "prisma:generate:postgres": "npm run prisma:sync:postgres && prisma generate --schema prisma/schema.postgres.prisma",
    "db:push:postgres": "npm run prisma:sync:postgres && prisma db push --schema prisma/schema.postgres.prisma",
    "verify:postgres": "node scripts/verify-postgres.mjs",
    "smoke:deploy": "node scripts/deploy-smoke-check.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prisma": "^6.4.1",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1010.0",
    "@aws-sdk/s3-request-presigner": "^3.1010.0"
  }
}
