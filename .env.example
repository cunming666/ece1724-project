# SQLite (default local)
DATABASE_URL="file:./dev.db"
# PostgreSQL example: postgresql://<user>:<password>@<host>:5432/<db>?sslmode=require
API_PORT="4000"
# PORT is automatically provided by most hosting providers (Render/Fly/Railway).
WEB_ORIGIN="http://localhost:5173"
# WEB_ORIGIN can be comma-separated for deployment (prod + preview domains).
VITE_API_URL="http://localhost:4000"

SPACES_REGION="your-spaces-region"
SPACES_ENDPOINT="https://your-spaces-endpoint"
SPACES_BUCKET="your-space-bucket"
SPACES_ACCESS_KEY="your-spaces-access-key"
SPACES_SECRET_KEY="your-spaces-secret-key"

OPENWEATHER_API_KEY="your-openweather-api-key"

